# ============================================================================
# SAP B1 MCP — Konfiguration
#
# Diese Datei neben das Binary (sapb1-mcp / sapb1-mcp.exe) als ".env" kopieren
# und ausfüllen, dann starten mit:  sapb1-mcp --env-file .env --host 127.0.0.1 --port 8000
#
# Legende:  [PFLICHT] = muss gesetzt sein · [Optional] = Default in (Klammern).
# Auskommentierte Zeilen (#) nutzen den Default. Vollständige Erläuterungen:
# docs/konfiguration.md
# ============================================================================


# --- Service Layer (Verbindung zu SAP B1) -----------------------------------

# [PFLICHT] Service-Layer-URL inkl. Version und abschließendem "/".
SAP_BASE_URL=https://ihr-sap-host:50000/b1s/v2/

# [PFLICHT] Wählbare CompanyDB(s) — eine oder mehrere, kommagetrennt.
SAP_DATABASES=SBO_IhreFirma

# [Optional] Zugriffsmodus (READ_ONLY). READ_WRITE schaltet die Schreib-Tools
# (anlegen/ändern/löschen) frei.
SAP_OPERATION_MODE=READ_ONLY

# [Optional] Selbstsigniertes SL-Zertifikat akzeptieren (false). Für Produktion
# möglichst ein gültiges Zertifikat verwenden.
SAP_ALLOW_SELF_SIGNED_CERT=false

# [Optional] Maximale Zeilen pro Ergebnisseite (200).
SAP_MAX_PAGE_SIZE=200

# [Optional] Parallele Service-Layer-Requests (10).
SAP_MAX_CONCURRENT_REQUESTS=10

# [Optional] Timeout je SL-Request in Sekunden (60).
SAP_TIMEOUT_SECONDS=60

# [Optional] Automatischer Logout einer untätigen SL-Session in Sekunden (1500).
SAP_IDLE_LOGOUT_SECONDS=1500


# --- Anmeldung ---------------------------------------------------------------

# [Optional] Prüfweg gegen die Service Layer:
#   basic (Default) = Benutzer/Passwort direkt an die SL (kein Keycloak).
#   ropc            = Benutzer/Passwort über Keycloak/SSO → JWT → SL
#                     (dann sind die SAP_KEYCLOAK_* unten PFLICHT).
SAP_AUTH_MODE=basic

# [Optional, EMPFOHLEN true] Login nur über Dialog (Elicit) bzw. Web-Login
# zulassen — nie als Chat-/Tool-Argument, damit Zugangsdaten nicht in den
# LLM-Kontext geraten.
SAP_DISABLE_INLINE_LOGIN=true

# [Optional] Öffentliche URL DIESER Instanz für den Browser-Login-Fallback
# (Hosts ohne native Eingabemaske, z. B. Claude Desktop). Daraus baut der Server
# die Login-URL <SAP_PUBLIC_URL>/login?t=…
#   LOKAL (gleiche Maschine): MIT Port → http://127.0.0.1:8000
#                             (Port MUSS zum Serverstart passen).
#   ZENTRAL/hinter Reverse-Proxy: die öffentliche HTTPS-URL → https://mcp.kunde.intern
#   (http:// ist nur für 127.0.0.1 erlaubt.)
SAP_PUBLIC_URL=http://127.0.0.1:8000


# --- Keycloak / SSO — NUR bei SAP_AUTH_MODE=ropc ----------------------------
# Bei basic komplett weglassen. Es handelt sich um das Instanz-Secret aus dem
# SLD (KEIN Endnutzer-Login). Kurzanleitung: docs/sso-keycloak.md

# [PFLICHT wenn ropc] Token-Endpoint des Keycloak-Realms.
# SAP_KEYCLOAK_TOKEN_URL=https://ihr-sap-host:40020/auth/realms/sapb1/protocol/openid-connect/token

# [PFLICHT wenn ropc] Client-ID.
# SAP_KEYCLOAK_CLIENT_ID=b1-B1ServiceLayers-1-main-sbo

# [PFLICHT wenn ropc] Client-Secret.
# SAP_KEYCLOAK_CLIENT_SECRET=

# [Optional] OAuth-Scopes (openid profile email B1.ServiceLayer). B1.ServiceLayer
# wird für den SL-Zugriff benötigt.
# SAP_KEYCLOAK_SCOPE=openid profile email B1.ServiceLayer


# --- Lizenz ------------------------------------------------------------------

# [Optional] Pfad zur Lizenzdatei. NICHT nötig, wenn "versino.key" neben dem
# Binary liegt (Auto-Discovery).
SAP_LICENSE_FILE=versino.key

# [Optional] Lizenz-Token direkt — Alternative zur Datei.
# SAP_LICENSE=<lizenz-token>


# --- Phone-Home / automatische Abo-Erneuerung -------------------------------

# [Optional] Enrollment-Token für Phone-Home / automatische Abo-Erneuerung.
# NORMALFALL: bereits in der versino.key eingebacken — hier NICHTS nötig.
# Diese Variable nur setzen, um den eingebauten Token zu überschreiben
# (Test/Staging). Übertragen werden nur Metadaten (customer_id, edition,
# version, Seat-Anzahl), keine Geschäftsdaten. Air-gapped: kein Token →
# der ausgelieferte Schlüssel gilt unverändert bis zum Ablaufdatum.
# SAP_ENROLLMENT_TOKEN=<override-token>

# [Optional] Intervall der Phone-Home-Validierung in Sekunden (3600).
# SAP_PHONE_HOME_INTERVAL_SECONDS=3600

# [Optional] Pfad für erneuerte Token (stiller Renewal-Cache). Default:
# "versino.renewed" neben der Lizenz bzw. dem Binary.
# SAP_LICENSE_CACHE_FILE=versino.renewed

# [Optional] Pfad der Installations-Identität (install_identity.json).
# SAP_INSTALL_IDENTITY_PATH=install_identity.json

# [Optional] Monotoner Zeit-Anker gegen Uhr-Rückstellung (Härtung für
# air-gapped Betrieb). Ohne Pfad deaktiviert.
# SAP_TIME_ANCHOR_PATH=versino.timeanchor
